#!/usr/bin/env bash
# Ruby/Bundler setup only (no Nix integration).

export BUNDLE_PATH="$PWD/.bundle"
export BUNDLE_BIN="$PWD/.bundle/bin"
export GEM_HOME="$PWD/.bundle"
export GEM_PATH="$PWD/.bundle"
PATH_add "$BUNDLE_BIN"

if command -v ruby >/dev/null 2>&1; then
  echo "direnv: using ruby $(ruby -v)"
else
  echo "direnv: ruby not found on PATH"
fi

if command -v bundle >/dev/null 2>&1; then
  echo "direnv: bundler $(bundle --version)"
else
  echo "direnv: bundler not found; run 'gem install bundler'"
fi

echo "Run: bundle install && bundle exec jekyll serve --livereload"
